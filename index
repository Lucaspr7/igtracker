<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>IG Tracker — Monitor de Seguidores</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<style>
  :root {
    --bg: #0a0a0f;
    --surface: #13131a;
    --surface2: #1c1c28;
    --border: #2a2a3d;
    --accent: #c77dff;
    --accent2: #7b2fff;
    --green: #3dffa0;
    --red: #ff4d6d;
    --yellow: #ffd60a;
    --text: #e8e8f0;
    --muted: #6b6b8a;
    --font: 'Syne', sans-serif;
    --mono: 'DM Mono', monospace;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Background mesh */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 80% 10%, rgba(124,47,255,0.12) 0%, transparent 60%),
      radial-gradient(ellipse 40% 40% at 10% 80%, rgba(199,125,255,0.08) 0%, transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1; }

  /* Header */
  header {
    border-bottom: 1px solid var(--border);
    padding: 20px 0;
    margin-bottom: 40px;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .logo-icon {
    width: 38px; height: 38px;
    background: linear-gradient(135deg, var(--accent2), var(--accent));
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
  }
  .logo h1 { font-size: 20px; font-weight: 800; letter-spacing: -0.5px; }
  .logo span { color: var(--accent); }

  .status-badge {
    display: flex; align-items: center; gap: 8px;
    padding: 6px 14px;
    border-radius: 100px;
    font-family: var(--mono);
    font-size: 12px;
    border: 1px solid var(--border);
    background: var(--surface);
  }
  .dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--muted);
    animation: pulse 2s infinite;
  }
  .dot.online { background: var(--green); }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* Login Panel */
  #login-panel {
    max-width: 420px;
    margin: 80px auto;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 40px;
    text-align: center;
  }
  #login-panel h2 {
    font-size: 28px; font-weight: 800;
    margin-bottom: 8px;
    background: linear-gradient(135deg, var(--text), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  #login-panel p { color: var(--muted); margin-bottom: 32px; font-size: 14px; }

  .field {
    margin-bottom: 16px;
    text-align: left;
  }
  .field label {
    display: block;
    font-size: 11px;
    font-family: var(--mono);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 6px;
  }
  .field input {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 16px;
    color: var(--text);
    font-family: var(--mono);
    font-size: 14px;
    outline: none;
    transition: border-color 0.2s;
  }
  .field input:focus { border-color: var(--accent); }

  .btn {
    width: 100%;
    padding: 13px;
    border: none;
    border-radius: 10px;
    background: linear-gradient(135deg, var(--accent2), var(--accent));
    color: white;
    font-family: var(--font);
    font-weight: 700;
    font-size: 15px;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.1s;
    margin-top: 8px;
  }
  .btn:hover { opacity: 0.9; transform: translateY(-1px); }
  .btn:active { transform: translateY(0); }
  .btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .btn.secondary {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--muted);
    font-size: 13px;
    margin-top: 4px;
  }

  .msg {
    margin-top: 16px;
    padding: 12px;
    border-radius: 8px;
    font-size: 13px;
    font-family: var(--mono);
    display: none;
  }
  .msg.error { background: rgba(255,77,109,0.1); border: 1px solid rgba(255,77,109,0.3); color: var(--red); }
  .msg.success { background: rgba(61,255,160,0.08); border: 1px solid rgba(61,255,160,0.2); color: var(--green); }

  /* Dashboard */
  #dashboard { display: none; }

  /* Stats grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 16px;
    margin-bottom: 32px;
  }
  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 24px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.2s;
  }
  .stat-card:hover { border-color: var(--accent); }
  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 80px; height: 80px;
    border-radius: 50%;
    opacity: 0.06;
  }
  .stat-card.purple::before { background: var(--accent); }
  .stat-card.red::before { background: var(--red); }
  .stat-card.green::before { background: var(--green); }
  .stat-card.yellow::before { background: var(--yellow); }

  .stat-label {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 10px;
  }
  .stat-value {
    font-size: 36px;
    font-weight: 800;
    letter-spacing: -1px;
    line-height: 1;
  }
  .stat-card.purple .stat-value { color: var(--accent); }
  .stat-card.red .stat-value { color: var(--red); }
  .stat-card.green .stat-value { color: var(--green); }
  .stat-card.yellow .stat-value { color: var(--yellow); }
  .stat-sub { font-size: 12px; color: var(--muted); margin-top: 6px; font-family: var(--mono); }

  /* Chart */
  .chart-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 28px;
    margin-bottom: 32px;
  }
  .section-title {
    font-size: 13px;
    font-family: var(--mono);
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 20px;
  }
  canvas { max-height: 200px; }

  /* Tables */
  .tables-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 32px;
  }
  @media (max-width: 700px) { .tables-grid { grid-template-columns: 1fr; } }

  .table-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }
  .table-header {
    padding: 18px 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .table-header .tag {
    font-size: 11px;
    font-family: var(--mono);
    padding: 2px 8px;
    border-radius: 100px;
  }
  .tag.red { background: rgba(255,77,109,0.15); color: var(--red); }
  .tag.green { background: rgba(61,255,160,0.12); color: var(--green); }

  .user-list { list-style: none; }
  .user-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 20px;
    border-bottom: 1px solid var(--border);
    transition: background 0.15s;
  }
  .user-item:last-child { border-bottom: none; }
  .user-item:hover { background: var(--surface2); }
  .user-info { display: flex; align-items: center; gap: 10px; }
  .avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent2), var(--accent));
    display: flex; align-items: center; justify-content: center;
    font-size: 12px;
    font-weight: 700;
    color: white;
    flex-shrink: 0;
  }
  .uname { font-size: 14px; font-weight: 600; }
  .udate { font-family: var(--mono); font-size: 11px; color: var(--muted); }
  .ig-link {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    text-decoration: none;
    opacity: 0.7;
  }
  .ig-link:hover { opacity: 1; }
  .empty-state {
    padding: 40px 20px;
    text-align: center;
    color: var(--muted);
    font-size: 13px;
    font-family: var(--mono);
  }

  /* Actions bar */
  .actions-bar {
    display: flex;
    gap: 12px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .action-btn {
    padding: 10px 20px;
    border-radius: 10px;
    font-family: var(--font);
    font-weight: 600;
    font-size: 13px;
    cursor: pointer;
    transition: all 0.2s;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
  }
  .action-btn:hover { border-color: var(--accent); color: var(--accent); }
  .action-btn.primary {
    background: linear-gradient(135deg, var(--accent2), var(--accent));
    border-color: transparent;
    color: white;
  }
  .action-btn.danger { border-color: rgba(255,77,109,0.3); color: var(--red); }
  .action-btn.danger:hover { background: rgba(255,77,109,0.1); }
  .action-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .last-check {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--muted);
    margin-left: auto;
    align-self: center;
  }

  /* Spinner */
  .spinner {
    display: inline-block;
    width: 14px; height: 14px;
    border: 2px solid rgba(255,255,255,0.3);
    border-top-color: white;
    border-radius: 50%;
    animation: spin 0.7s linear infinite;
    vertical-align: middle;
    margin-right: 6px;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
</style>
</head>
<body>

<header>
  <div class="container">
    <div class="header-inner">
      <div class="logo">
        <div class="logo-icon">📡</div>
        <h1>IG<span>Tracker</span></h1>
      </div>
      <div class="status-badge">
        <div class="dot" id="status-dot"></div>
        <span id="status-text">Desconectado</span>
      </div>
    </div>
  </div>
</header>

<div class="container">

  <!-- LOGIN -->
  <div id="login-panel">
    <h2>Conectar conta</h2>
    <p>Faça login uma vez — o sistema monitora automaticamente a partir daí.</p>

    <div class="field">
      <label>Usuário do Instagram</label>
      <input type="text" id="inp-user" placeholder="seu_usuario" autocomplete="username">
    </div>
    <div class="field">
      <label>Senha</label>
      <input type="password" id="inp-pass" placeholder="••••••••" autocomplete="current-password">
    </div>
    <div class="field" id="field-2fa" style="display:none">
      <label>Código 2FA</label>
      <input type="text" id="inp-2fa" placeholder="000000" maxlength="6">
    </div>

    <button class="btn" id="btn-login" onclick="doLogin()">Entrar e começar monitoramento</button>
    <div class="msg" id="login-msg"></div>
  </div>

  <!-- DASHBOARD -->
  <div id="dashboard">

    <div class="actions-bar">
      <button class="action-btn primary" id="btn-check" onclick="manualCheck()">🔍 Verificar agora</button>
      <button class="action-btn danger" onclick="doLogout()">Sair</button>
      <span class="last-check" id="last-check-label">Última verificação: —</span>
    </div>

    <div class="stats-grid">
      <div class="stat-card purple">
        <div class="stat-label">Seguidores atuais</div>
        <div class="stat-value" id="stat-followers">—</div>
        <div class="stat-sub">@<span id="stat-username">—</span></div>
      </div>
      <div class="stat-card red">
        <div class="stat-label">Unfollows detectados</div>
        <div class="stat-value" id="stat-unfollows">—</div>
        <div class="stat-sub">total registrado</div>
      </div>
      <div class="stat-card green">
        <div class="stat-label">Novos seguidores</div>
        <div class="stat-value" id="stat-new">—</div>
        <div class="stat-sub">total registrado</div>
      </div>
      <div class="stat-card yellow">
        <div class="stat-label">Verificações feitas</div>
        <div class="stat-value" id="stat-checks">—</div>
        <div class="stat-sub">auto + manuais</div>
      </div>
    </div>

    <div class="chart-card">
      <div class="section-title">Histórico de seguidores</div>
      <canvas id="chart-followers"></canvas>
    </div>

    <div class="tables-grid">
      <div class="table-card">
        <div class="table-header">
          <span style="font-size:14px;font-weight:700;">Unfollows</span>
          <span class="tag red" id="unf-count">0</span>
        </div>
        <ul class="user-list" id="list-unfollowers">
          <li class="empty-state">Nenhum unfollow detectado ainda.<br>Aguarde a próxima verificação.</li>
        </ul>
      </div>
      <div class="table-card">
        <div class="table-header">
          <span style="font-size:14px;font-weight:700;">Novos seguidores</span>
          <span class="tag green" id="new-count">0</span>
        </div>
        <ul class="user-list" id="list-new-followers">
          <li class="empty-state">Nenhum novo seguidor detectado ainda.</li>
        </ul>
      </div>
    </div>

  </div>
</div>

<script>
let chartInstance = null;

function showMsg(id, text, type) {
  const el = document.getElementById(id);
  el.textContent = text;
  el.className = `msg ${type}`;
  el.style.display = 'block';
}

async function doLogin() {
  const user = document.getElementById('inp-user').value.trim();
  const pass = document.getElementById('inp-pass').value.trim();
  const code2fa = document.getElementById('inp-2fa').value.trim();
  const btn = document.getElementById('btn-login');

  if (!user || !pass) { showMsg('login-msg', 'Preencha usuário e senha.', 'error'); return; }

  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span>Conectando...';

  const res = await fetch('/login', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({username: user, password: pass, code_2fa: code2fa})
  });
  const data = await res.json();
  btn.disabled = false;
  btn.textContent = 'Entrar e começar monitoramento';

  if (data.ok) {
    showMsg('login-msg', data.message, 'success');
    setTimeout(() => { showDashboard(); loadStats(); }, 1000);
  } else {
    showMsg('login-msg', data.error, 'error');
    if (data.need_2fa) {
      document.getElementById('field-2fa').style.display = 'block';
    }
  }
}

async function doLogout() {
  if (!confirm('Sair e encerrar monitoramento?')) return;
  await fetch('/logout', {method: 'POST'});
  location.reload();
}

async function manualCheck() {
  const btn = document.getElementById('btn-check');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span>Verificando...';
  const res = await fetch('/check', {method: 'POST'});
  const data = await res.json();
  btn.disabled = false;
  btn.textContent = '🔍 Verificar agora';
  if (data.ok) loadStats();
}

function showDashboard() {
  document.getElementById('login-panel').style.display = 'none';
  document.getElementById('dashboard').style.display = 'block';
}

function fmtDate(iso) {
  if (!iso) return '—';
  const d = new Date(iso);
  return d.toLocaleString('pt-BR');
}

function renderList(listId, items, type) {
  const ul = document.getElementById(listId);
  if (!items || items.length === 0) {
    ul.innerHTML = `<li class="empty-state">Nenhum registro ainda.</li>`;
    return;
  }
  ul.innerHTML = items.map(u => `
    <li class="user-item">
      <div class="user-info">
        <div class="avatar">${(u.username||'?')[0].toUpperCase()}</div>
        <div>
          <div class="uname">@${u.username || '—'}</div>
          <div class="udate">${fmtDate(u.detected_at)}</div>
        </div>
      </div>
      <a class="ig-link" href="https://instagram.com/${u.username}" target="_blank">↗ ver</a>
    </li>
  `).join('');
}

async function loadStats() {
  const res = await fetch('/api/stats');
  const d = await res.json();

  if (d.logged_in) {
    document.getElementById('status-dot').className = 'dot online';
    document.getElementById('status-text').textContent = '@' + d.username;
    showDashboard();
  }

  document.getElementById('stat-username').textContent = d.username || '—';
  document.getElementById('stat-followers').textContent = d.current_followers?.toLocaleString('pt-BR') || '—';
  document.getElementById('stat-unfollows').textContent = d.total_unfollowers?.toLocaleString('pt-BR') || '0';
  document.getElementById('stat-new').textContent = d.total_new?.toLocaleString('pt-BR') || '0';
  document.getElementById('stat-checks').textContent = d.total_checks || '0';
  document.getElementById('last-check-label').textContent = 'Última verificação: ' + fmtDate(d.last_check);
  document.getElementById('unf-count').textContent = d.total_unfollowers || 0;
  document.getElementById('new-count').textContent = d.total_new || 0;

  renderList('list-unfollowers', d.unfollowers, 'unf');
  renderList('list-new-followers', d.new_followers, 'new');

  // Chart
  if (d.chart_labels && d.chart_labels.length > 0) {
    const ctx = document.getElementById('chart-followers').getContext('2d');
    if (chartInstance) chartInstance.destroy();
    chartInstance = new Chart(ctx, {
      type: 'line',
      data: {
        labels: d.chart_labels,
        datasets: [{
          label: 'Seguidores',
          data: d.chart_values,
          borderColor: '#c77dff',
          backgroundColor: 'rgba(199,125,255,0.08)',
          borderWidth: 2,
          pointBackgroundColor: '#c77dff',
          pointRadius: 4,
          fill: true,
          tension: 0.4
        }]
      },
      options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
          x: { ticks: { color: '#6b6b8a', font: { family: 'DM Mono', size: 11 } }, grid: { color: '#2a2a3d' } },
          y: { ticks: { color: '#6b6b8a', font: { family: 'DM Mono', size: 11 } }, grid: { color: '#2a2a3d' } }
        }
      }
    });
  }
}

// Init
loadStats();
setInterval(loadStats, 30000); // atualiza painel a cada 30s
</script>
</body>
</html>
